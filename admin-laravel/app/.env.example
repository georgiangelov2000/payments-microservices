APP_NAME="PayFlow Admin"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8083

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12
HASH_DRIVER=argon2id

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=payments-db
DB_PORT=5432
DB_DATABASE=payments
DB_USERNAME=payments_api
DB_PASSWORD=strong_rw_password

LOGS_DB_HOST=payments-logs-db
LOGS_DB_PORT=5432
LOGS_DB_DATABASE=logs
LOGS_DB_USERNAME=webhook_api
LOGS_DB_PASSWORD=strong_rw_password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_COOKIE=payflow_admin_session

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=file

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=admin_

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_FROM_ADDRESS="admin@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
VITE_PORT=5174

ADMIN_NAME="PayFlow Admin"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin-password
