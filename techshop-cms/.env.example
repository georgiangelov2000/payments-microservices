CMS_PORT=3002
CMS_PUBLIC_URL=http://localhost:3002
CMS_DATA_DIR=/data
CMS_ADMIN_TOKEN=change-me-local-admin-token

MERCHANT_DEMO_URL=http://localhost:3001
PAYMENT_GATEWAY_URL=http://gateway

# Required in non-local environments. Webhooks are rejected when this is set and
# the provider does not send a valid x-techshop-signature header.
CMS_WEBHOOK_SECRET=change-me-webhook-secret
WEBHOOK_MAX_SKEW_SECONDS=300

# Optional: forward validated completed-payment events to another internal URL.
# Example: http://saas-laravel:8000/internal/merchant-webhooks/techshop
WEBHOOK_FORWARD_URL=
WEBHOOK_FORWARD_TOKEN=
